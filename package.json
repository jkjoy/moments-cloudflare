{
  "name": "moments-cloudflare",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt generate",
    "dev": "npm run db:init && npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "nuxi typecheck && tsc --noEmit -p worker/tsconfig.json",
    "db:create": "wrangler d1 create moments-db",
    "db:init": "wrangler d1 execute moments-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute moments-db --remote --file=./schema.sql",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@fancyapps/ui": "^5.0.36",
    "@iconify-json/carbon": "^1.2.8",
    "@iconify-json/heroicons": "^1.2.2",
    "@iconify-json/icon-park-solid": "^1.2.2",
    "@iconify-json/jam": "^1.2.3",
    "@iconify-json/lets-icons": "^1.2.1",
    "@iconify-json/octicon": "^1.2.5",
    "@iconify-json/solar": "^1.2.2",
    "@nuxt/icon": "1.12.0",
    "@nuxt/ui": "^2.22.0",
    "@nuxtjs/color-mode": "^3.5.2",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "hono": "^4.0.0",
    "markdown-it": "^14.1.0",
    "nuxt": "^3.17.0",
    "resend": "^6.5.2",
    "sortablejs": "^1.15.6",
    "v-calendar": "^3.1.2",
    "vue": "latest",
    "vue-sonner": "^1.3.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260409.1",
    "@shikijs/markdown-it": "^1.29.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/grecaptcha": "^3.0.9",
    "@types/markdown-it": "^14.1.2",
    "@vueuse/core": "^10.11.1",
    "@vueuse/nuxt": "^10.11.1",
    "dayjs": "^1.11.13",
    "dayjs-nuxt": "^2.1.11",
    "sass": "^1.87.0",
    "shiki": "^1.29.2",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.10",
    "wrangler": "4.81.0"
  }
}
